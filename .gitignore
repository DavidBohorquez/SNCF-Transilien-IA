# Only retain Python scripts and images (png/jpg/jpeg/gif/webp)
# Everything else (including csv, ipynb, venvs, checkpts, logs, etc) is ignored.

# Ignore everything by default
*

# But NOT these:
!*.py
!*.png
!*.jpg
!*.jpeg
!*.gif
!*.webp

# Retain .gitignore itself
!.gitignore

# Exclude hidden dotfiles except .gitignore
.*
!.gitignore

# Do not ignore folders (so we retain subfolder structure)
!*/
